# NOVA Environment Configuration
# Copy this to .env and fill in your values

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (send /start to @userinfobot to get yours)
# Comma-separated for multiple users
AUTHORIZED_CHAT_IDS=your_chat_id_here

# Your name (NOVA will use this to address you)
OWNER_NAME=YourName
